#!/bin/sh
set -eu

msg_file="${1:-}"
if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
  echo "commit-msg: missing commit message file path" >&2
  exit 1
fi

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

escape_toml_string() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

is_absolute_manifest_path() {
  case "$1" in
    /* | [A-Za-z]:/* | [A-Za-z]:\\* | //*) return 0 ;;
    \\\\*) return 0 ;;
    *) return 1 ;;
  esac
}

run_with_manifest() {
  manifest_path="$1"
  if [ ! -f "$manifest_path" ]; then
    return 1
  fi
  exec cargo run --quiet --manifest-path "$manifest_path" -- commit-msg --repo-root "$repo_root" --commit-msg-file "$msg_file"
}

run_with_isolated_source() {
  source_path="$repo_root/tools/repo-check/src/main.rs"
  if [ ! -f "$source_path" ]; then
    return 1
  fi
  runner_dir=$(mktemp -d "${TMPDIR:-/tmp}/omne-repo-check-runner.XXXXXX")
  trap 'rm -rf "$runner_dir"' EXIT HUP INT TERM
  manifest_path="$runner_dir/Cargo.toml"
  escaped_source=$(escape_toml_string "$source_path")
  cat >"$manifest_path" <<EOF
[package]
name = "omne-repo-check-runner"
version = "0.0.0"
edition = "2024"

[workspace]

[dependencies]
serde_json = "1"
toml = "0.8"

[[bin]]
name = "omne-repo-check"
path = "$escaped_source"
EOF
  export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$repo_root/.git/omne-repo-check-target}"
  if cargo run --quiet --manifest-path "$manifest_path" -- commit-msg --repo-root "$repo_root" --commit-msg-file "$msg_file"; then
    status=0
  else
    status=$?
  fi
  rm -rf "$runner_dir"
  exit "$status"
}

manifest_override="${OMNE_REPO_CHECK_MANIFEST:-}"
if [ -n "$manifest_override" ]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "commit-msg: cargo is required when OMNE_REPO_CHECK_MANIFEST is set." >&2
    exit 1
  fi
  if is_absolute_manifest_path "$manifest_override"; then
    run_with_manifest "$manifest_override"
  else
    run_with_manifest "$repo_root/$manifest_override"
  fi
  echo "commit-msg: OMNE_REPO_CHECK_MANIFEST does not point to a manifest: $manifest_override" >&2
  exit 1
fi

binary_override="${OMNE_REPO_CHECK_BIN:-}"
if [ -n "$binary_override" ]; then
  exec "$binary_override" commit-msg --repo-root "$repo_root" --commit-msg-file "$msg_file"
fi

default_source="$repo_root/tools/repo-check/src/main.rs"
default_manifest="$repo_root/tools/repo-check/Cargo.toml"
if command -v cargo >/dev/null 2>&1; then
  if [ -f "$default_source" ]; then
    run_with_isolated_source
  fi
  if [ -f "$default_manifest" ]; then
    run_with_manifest "$default_manifest"
  fi
fi

if command -v omne-repo-check >/dev/null 2>&1; then
  exec omne-repo-check commit-msg --repo-root "$repo_root" --commit-msg-file "$msg_file"
fi

if command -v repo-check >/dev/null 2>&1; then
  exec repo-check commit-msg --repo-root "$repo_root" --commit-msg-file "$msg_file"
fi

cat >&2 <<'EOF'
commit-msg: unable to locate a repo-check runner.

Supported forms:
- repo-local source runner: tools/repo-check/src/main.rs
- repo-local manifest override: OMNE_REPO_CHECK_MANIFEST=path/to/Cargo.toml
- external binary override: OMNE_REPO_CHECK_BIN=/path/to/omne-repo-check
- external binary on PATH: omne-repo-check or repo-check
EOF
exit 1
