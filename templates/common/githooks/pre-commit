#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

is_absolute_manifest_path() {
  case "$1" in
    /* | [A-Za-z]:/* | [A-Za-z]:\\* | //*) return 0 ;;
    \\\\*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_check_config_value() {
  key="$1"
  config_path="$repo_root/repo-check.toml"
  if [ ! -f "$config_path" ]; then
    return 1
  fi
  sed -n "s/^${key}[[:space:]]*=[[:space:]]*['\"]\\(.*\\)['\"][[:space:]]*$/\\1/p" "$config_path" | head -n 1
}

resolve_rust_workspace_manifest() {
  project_kind="$(repo_check_config_value project_kind || true)"
  if [ "$project_kind" != "rust" ]; then
    return 1
  fi

  package_manifest_path="$(repo_check_config_value package_manifest_path || true)"
  if [ -z "$package_manifest_path" ]; then
    return 1
  fi

  package_manifest="$repo_root/$package_manifest_path"
  if [ ! -f "$package_manifest" ]; then
    return 1
  fi

  search_dir=$(dirname "$package_manifest_path")
  if [ -z "$search_dir" ] || [ "$search_dir" = "." ]; then
    search_dir="."
  fi

  while [ "$search_dir" != "/" ] && [ "$search_dir" != "." ]; do
    candidate="$repo_root/$search_dir/Cargo.toml"
    if [ -f "$candidate" ] && grep -Eq '^[[:space:]]*\[workspace\][[:space:]]*$' "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
    next_dir=$(dirname "$search_dir")
    if [ "$next_dir" = "$search_dir" ]; then
      break
    fi
    search_dir="$next_dir"
  done

  candidate="$repo_root/Cargo.toml"
  if [ -f "$candidate" ] && grep -Eq '^[[:space:]]*\[workspace\][[:space:]]*$' "$candidate"; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

run_with_manifest() {
  manifest_path="$1"
  if [ ! -f "$manifest_path" ]; then
    return 1
  fi
  exec cargo run --quiet --manifest-path "$manifest_path" -- pre-commit --repo-root "$repo_root"
}

run_with_workspace_manifest() {
  workspace_manifest="$1"
  if [ ! -f "$workspace_manifest" ]; then
    return 1
  fi
  exec cargo run --quiet --manifest-path "$workspace_manifest" -p omne-repo-check -- pre-commit --repo-root "$repo_root"
}

manifest_override="${OMNE_REPO_CHECK_MANIFEST:-}"
if [ -n "$manifest_override" ]; then
  if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo is required when OMNE_REPO_CHECK_MANIFEST is set." >&2
    exit 1
  fi
  if is_absolute_manifest_path "$manifest_override"; then
    run_with_manifest "$manifest_override"
  else
    run_with_manifest "$repo_root/$manifest_override"
  fi
  echo "pre-commit: OMNE_REPO_CHECK_MANIFEST does not point to a manifest: $manifest_override" >&2
  exit 1
fi

binary_override="${OMNE_REPO_CHECK_BIN:-}"
if [ -n "$binary_override" ]; then
  exec "$binary_override" pre-commit --repo-root "$repo_root"
fi

default_manifest="$repo_root/tools/repo-check/Cargo.toml"
if [ -f "$default_manifest" ] && command -v cargo >/dev/null 2>&1; then
  workspace_manifest="$(resolve_rust_workspace_manifest || true)"
  if [ -n "$workspace_manifest" ]; then
    run_with_workspace_manifest "$workspace_manifest"
  fi
  run_with_manifest "$default_manifest"
fi

if command -v omne-repo-check >/dev/null 2>&1; then
  exec omne-repo-check pre-commit --repo-root "$repo_root"
fi

if command -v repo-check >/dev/null 2>&1; then
  exec repo-check pre-commit --repo-root "$repo_root"
fi

cat >&2 <<'EOF'
pre-commit: unable to locate a repo-check runner.

Supported forms:
- repo-local manifest: tools/repo-check/Cargo.toml
- repo-local manifest override: OMNE_REPO_CHECK_MANIFEST=path/to/Cargo.toml
- external binary override: OMNE_REPO_CHECK_BIN=/path/to/omne-repo-check
- external binary on PATH: omne-repo-check or repo-check
EOF
exit 1
